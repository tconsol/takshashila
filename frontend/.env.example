# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api/v1

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Takshashila LMS
VITE_APP_VERSION=1.0.0

# ─── Stripe (public key only never put secret key here) ─────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── Razorpay (public key only) ───────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_

# ─── WebRTC / TURN (native in-app live classes — no Agora needed) ────────────
# Optional TURN server for users behind symmetric NAT (mobile hotspots, corp firewalls)
# Leave empty to use Google STUN only (works for most home/office networks)
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ─── Google OAuth (sign-in button) ────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=

# ─── Firebase (browser push notifications / PWA) ─────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ─── Sentry (frontend error monitoring) ───────────────────────────────────────
VITE_SENTRY_DSN=
