# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/takshashila

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<min_32_char_random_string>
JWT_ACCESS_SECRET=<min_32_char_random_string>
JWT_REFRESH_SECRET=<min_32_char_random_string>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookies & CORS ───────────────────────────────────────────────────────────
COOKIE_SECRET=<min_32_char_random_string>
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@takshashila.com
EMAIL_FROM=noreply@takshashila.com

# ─── GCP Cloud Storage ────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GCP_KEY_FILE=./gcp-service-account.json

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Zoom (live class video) ──────────────────────────────────────────────────
# https://marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ─── Google OAuth + Google Meet ───────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Calendar API, Google Meet API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json

# ─── Agora (WebRTC in-app video ClassRoomPage) ─────────────────────────────
# https://console.agora.io → Project Management → Create Project
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_EXPIRE_SECONDS=3600

# ─── Twilio (SMS OTP / WhatsApp notifications) ────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ─── Firebase (push notifications mobile / PWA) ────────────────────────────
# https://console.firebase.google.com → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_VAPID_KEY=

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
# https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
