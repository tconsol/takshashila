# Server is on localhost:4000/api/v1
# Android emulator → use 10.0.2.2 (maps to host machine's localhost)
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api/v1

# iOS simulator → uncomment below and comment out the line above
# EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# Physical device → use your machine's local IP (e.g. 192.168.x.x)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:4000/api/v1
