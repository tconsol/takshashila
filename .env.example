# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://root:rootpassword@localhost:27017/takshashila?authSource=admin

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────
COOKIE_SECRET=change_me_cookie_secret_min_32_chars

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.mailhog.io
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@takshashila.com

# ─── GCP ──────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GCP_KEY_FILE=

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Razorpay ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
